# Google Sheets
SPREADSHEET_ID=19XxPdDT3ezxriN5hVgXUZ4z4dYxIxU-fNblS1pOtR0A
# 예: 레노버 아이디어 탭 11
WORKSHEET_NAME=레노버 아이디어 탭 11

# 인증 방식: auto | oauth | service_account
GOOGLE_AUTH_MODE=auto

# OAuth (데스크톱 클라이언트 JSON)
GOOGLE_OAUTH_CLIENT_PATH=credentials/oauth-client.json
GOOGLE_TOKEN_PATH=credentials/token.json

# 서비스 계정 (선택)
GOOGLE_CREDENTIALS_PATH=credentials/service-account.json

# 생기부 작성 (Gemini)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
# GEMINI_MIN_INTERVAL_SEC=3
# GEMINI_MAX_RETRIES=0

# 생기부 관리자 웹 (server.py)
ADMIN_PASSWORD=dev-local
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
SGB_HOST=127.0.0.1
SGB_PORT=8787
SGB_PLAN=admin
SGB_ALLOWED_ORIGINS=https://mansejin.com,https://www.mansejin.com,https://sgb.mansejin.com,http://localhost:8080,http://127.0.0.1:8080

# 개인정보·데이터 보호 (기본: 작성본 서버 미저장, 메모 암호화)
SGB_STORE_GENERATED=0
SGB_ENCRYPT_DATA=1
# 32바이트 키 (base64). 생성: python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
SGB_DATA_KEY=

# AI 전송 전 PII 마스킹 (전화·이메일·주소·주민번호, 기본 켜짐)
SGB_MASK_PII=1
# 학생 실명도 마스킹 (기본 끔 — 품질 저하 가능)
# SGB_MASK_STUDENT_NAMES=0
