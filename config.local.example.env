# 로컬 실험용 — NAS .env 와 분리해서 사용
# 사용법: cp config.local.example.env .env.local
#         ./scripts/dev-local.sh

# GEMINI_API_KEY=your-key-here

# 모델 프로필 (docs/model-cost-local.md 참고)
# split — 작성·샘플분석=Pro, 맞춤법·편집=Flash (기본, 권장)
# flash — 전부 Flash (비용 최소, 품질 하락 가능)
# pro   — 전부 Pro (품질 최대, 비용 최대)
GEMINI_MODEL_PROFILE=split

GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_MODEL_FAST=gemini-2.5-flash

# 작성 후 자동 맞춤법 1회 생략 (호출 50% 절감, 띄어쓰기 품질 소폭 하락)
# GEMINI_SKIP_PROOFREAD=1

# GEMINI_MIN_INTERVAL_SEC=3
# GEMINI_MAX_RETRIES=0

SGB_PLAN=admin
SGB_ENCRYPT_DATA=0
