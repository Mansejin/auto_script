# NAS 배포용 .env 예시 — 복사: cp config.nas.example.env .env

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview

ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

SGB_HOST=0.0.0.0
SGB_PORT=8787
SGB_ALLOWED_ORIGINS=https://mansejin.com,https://www.mansejin.com

# Cloudflare Tunnel (선택) — docs/deploy-mansejin.md 참고
# CLOUDFLARE_TUNNEL_TOKEN=
