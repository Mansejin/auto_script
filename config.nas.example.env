# NAS 배포용 .env 예시 — 복사: cp config.nas.example.env .env

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
# Gemini 호출 간격(초). 분당 제한(RPM) 완화. 기본 3
# GEMINI_MIN_INTERVAL_SEC=3
# 자동 재시도 횟수(추가 시도). 429/RPM 오류는 재시도 안 함. 기본 0
# GEMINI_MAX_RETRIES=0

ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

SGB_HOST=0.0.0.0
SGB_PORT=8787
SGB_PLAN=admin
SGB_ALLOWED_ORIGINS=https://mansejin.com,https://www.mansejin.com,https://sgb.mansejin.com

# 개인정보·데이터 보호 (PC .env 와 동일 값 필수)
SGB_STORE_GENERATED=0
SGB_ENCRYPT_DATA=1
# 32바이트 키 (base64url). PC에서 복사: grep SGB_DATA_KEY .env
# 생성: python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
SGB_DATA_KEY=

# AI 전송 전 PII 마스킹 (기본 켜짐)
SGB_MASK_PII=1

# HTTPS 배포 시 쿠키 Secure (sgb.mansejin.com)
# SGB_COOKIE_SECURE=1

# git pull branch for nas-docker-update.sh (optional; GitHub Actions uses pushed branch)
# SGB_DEPLOY_BRANCH=main

# Synology SSH users often need sudo for docker socket
# SGB_DOCKER_SUDO=1

# Cloudflare Tunnel (선택) — docs/deploy-mansejin.md 참고
# CLOUDFLARE_TUNNEL_TOKEN=
