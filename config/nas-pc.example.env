# PC에서 나스 접속 설정 (복사: config/nas-pc.local.env)
# 이 파일은 git에 올라가지 않습니다.

# SSH — 아래 중 하나만 쓰면 됩니다 (Tailscale 있으면 그게 제일 편함)
NAS_SSH_HOST=ohola.synology.me
# NAS_SSH_HOST=100.x.x.x
NAS_SSH_PORT=22
NAS_USER=your_synology_username

# SSH config 별칭 (scripts/nas-pc.ps1 setup 후 ssh saenggibu-nas 로 접속)
NAS_SSH_ALIAS=saenggibu-nas

# 나스 안 프로젝트 경로
NAS_REPO_PATH=/volume1/docker/saenggibu

# SMB — PC 탐색기에 docker 폴더를 드라이브로 붙이기
# DSM에서 'docker' 공유 폴더를 만든 뒤 아래를 맞추세요 (docs/nas-pc-access.md)
NAS_SMB_HOST=ohola.synology.me
# NAS_SMB_HOST=100.x.x.x
NAS_SMB_SHARE=docker
NAS_DRIVE_LETTER=Z

# (선택) SSH 키 경로 — 비우면 비밀번호 로그인
# NAS_SSH_KEY=C:\Users\you\.ssh\id_ed25519
