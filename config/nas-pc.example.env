# PC에서 나스 접속 설정 (복사: config/nas-pc.local.env)
# 이 파일은 git에 올라가지 않습니다.

NAS_USER=your_synology_username
NAS_SSH_PORT=22
NAS_REPO_PATH=/volume1/docker/saenggibu

# 외부 — Tailscale (밖·스튜디오)
NAS_SSH_HOST=100.x.x.x
NAS_SSH_ALIAS=saenggibu-nas
NAS_SMB_HOST=100.x.x.x

# 집 안 — 로컬 LAN (같은 공유기/직결)
NAS_SSH_HOST_LOCAL=169.254.158.191
NAS_SSH_ALIAS_LOCAL=saenggibu-nas-local
NAS_SMB_HOST_LOCAL=169.254.158.191

NAS_SMB_SHARE=docker
NAS_DRIVE_LETTER=Z

# (선택) SSH 키 — 비우면 비밀번호 로그인
# NAS_SSH_KEY=C:\Users\you\.ssh\id_ed25519
